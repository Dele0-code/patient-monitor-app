LOCAL_MODEL_NAME=qwen2.5:0.5b
ECG_MODEL_PATH=ecg_model_100hz.pt
SQLITE_PATH=patient_monitor.db
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.89:5173
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=patient-monitor
