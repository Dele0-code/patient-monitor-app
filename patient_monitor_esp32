// --- Wi-Fi (local network only -- no internet required past this point) ---
const char* ssid = "BME STARLINK";
const char* password = "e-medi987321";

// --- MQTT (Raspberry Pi broker on the same LAN) ---
const char* mqtt_broker = "192.168.1.89";   // your Pi's IP
const int   mqtt_port   = 1883;
const char* patient_id  = "PT-000001";       // which patient this device is attached to

WiFiClient espClient;
PubSubClient mqttClient(espClient);
unsigned long lastMqttAttempt = 0;
const unsigned long mqttRetryInterval = 5000;

// --- OLED SPI Settings ---
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_MOSI  23
#define OLED_CLK   18
#define OLED_DC    19
#define OLED_CS    5
#define OLED_RESET 15
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, OLED_MOSI, OLED_CLK, OLED_DC, OLED_RESET, OLED_CS);

// --- DS18B20 Temp Settings ---
#define ONE_WIRE_BUS 4
OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);
float bodyTempC = 0.0;
unsigned long lastTempRequest = 0;

// --- MAX30102 Settings ---
MAX30105 particleSensor;
uint32_t irBuffer[100];
uint32_t redBuffer[100];
int32_t bufferLength = 100;
int bufferIndex = 0;

int32_t spo2;
int8_t validSPO2;
int32_t heartRate;
int8_t validHeartRate;

// --- ECG Pinout & Filtering ---
const int LO_PLUS  = 32;
const int LO_MINUS = 33;
const int ECG_PIN  = 34;

const float fs = 100.0;
const unsigned long samplingPeriod = 1000000UL / fs;
unsigned long lastSampleTime = 0;
const float dt = 1.0 / fs;

const float low_cutoff  = 40.0;
const float high_cutoff = 0.5;
float alphaLPF, alphaHPF;
float yLPF_prev = 0, yHPF_prev = 0, xHPF_prev = 0;

const float f0 = 50.0;
const float Q  = 30.0;
float notch_b0, notch_b1, notch_b2, notch_a1, notch_a2;
float notch_x1 = 0, notch_x2 = 0, notch_y1 = 0, notch_y2 = 0;

const int ECG_PEAK_THRESHOLD = 2600;
const unsigned long ECG_REFRACTORY_MS = 250;
unsigned long lastEcgPeakTime = 0;
float ecgBpm = 0.0;
float ecgBpmHistory[5];
int ecgBpmIndex = 0;
int ecgBeatCount = 0;

// --- NEW: raw ECG window buffer for the 1D-CNN (100 samples = 1 second at 100Hz) ---
float ecgRawBuffer[100];
int ecgRawIndex = 0;

// --- Filter Functions ---
float highPassFilter(float x) {
  float y = alphaHPF * (yHPF_prev + x - xHPF_prev);
  yHPF_prev = y; xHPF_prev = x; return y;
}

float lowPassFilter(float x) {
  yLPF_prev = alphaLPF * yLPF_prev + (1 - alphaLPF) * x;
  return yLPF_prev;
}

float notchFilter(float x) {
  float y = notch_b0 * x + notch_b1 * notch_x1 + notch_b2 * notch_x2
                         - notch_a1 * notch_y1 - notch_a2 * notch_y2;
  notch_x2 = notch_x1; notch_x1 = x; notch_y2 = notch_y1; notch_y1 = y; return y;
}

// --- Keep MQTT connected without blocking the sensor loop or OLED ---
void maintainMqttConnection() {
  if (!mqttClient.connected()) {
    unsigned long now = millis();
    if (now - lastMqttAttempt > mqttRetryInterval) {
      lastMqttAttempt = now;
      Serial.print("Attempting MQTT connection...");
      String clientId = "ESP32-" + String(patient_id);
      if (mqttClient.connect(clientId.c_str())) {
        Serial.println("connected");
      } else {
        Serial.print("failed, rc=");
        Serial.println(mqttClient.state());
        // Sensors and OLED keep running regardless -- this failure only
        // means this second's reading won't reach the dashboard/history.
      }
    }
    return;
  }
  mqttClient.loop();
}

// --- Publish one second's worth of telemetry over MQTT ---
void publishTelemetry() {
  if (!mqttClient.connected()) {
    Serial.println("MQTT offline -- skipping publish (display still live locally)");
    return;
  }

  DynamicJsonDocument doc(4096);
  doc["patient_id"] = patient_id;
  doc["timestamp"] = millis();
  doc["spo2"] = (spo2 > 0) ? spo2 : 0;
  doc["max_bpm"] = (heartRate > 0) ? heartRate : 0;
  doc["temperature_c"] = (bodyTempC > -10.0) ? bodyTempC : 0;
  doc["nibp_sys"] = nullptr;   // no NIBP sensor on this hardware -- left null on purpose
  doc["nibp_dia"] = nullptr;

  JsonArray ecgArray = doc.createNestedArray("raw_ecg");
  for (int i = 0; i < 100; i++) {
    ecgArray.add(ecgRawBuffer[i]);
  }

  char payload[4096];
  size_t len = serializeJson(doc, payload);

  char topic[64];
  snprintf(topic, sizeof(topic), "patient-monitor/%s/telemetry", patient_id);

  if (mqttClient.publish(topic, payload, len)) {
    Serial.println("Published telemetry");
  } else {
    Serial.println("Publish failed -- payload likely exceeds MQTT buffer size");
  }
}

void setup() {
  Serial.begin(115200);
  delay(500);

  // 1. Setup OLED
  if (!display.begin(SSD1306_SWITCHCAPVCC)) {
    Serial.println("SSD1306 allocation failed");
    for (;;);
  }
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0, 10);
  display.println("Booting System...");
  display.display();

  // 2. Connect to Wi-Fi (local network -- no internet required)
  display.setCursor(0, 25);
  display.print("WiFi: ");
  display.println(ssid);
  display.display();

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected!");
  display.setCursor(0, 40);
  display.println("WiFi Connected!");
  display.display();
  delay(1000);

  // 2b. Setup MQTT
  mqttClient.setServer(mqtt_broker, mqtt_port);
  mqttClient.setBufferSize(4096);   // default 256 bytes is far too small for a 100-sample ECG array

  // 3. Setup DS18B20 (Non-blocking mode)
  sensors.begin();
  sensors.setWaitForConversion(false);
  sensors.requestTemperatures();
  lastTempRequest = millis();

  // 4. Setup ECG
  pinMode(LO_PLUS, INPUT);
  pinMode(LO_MINUS, INPUT);
  analogReadResolution(12);

  alphaLPF = exp(-2 * PI * low_cutoff * dt);
  alphaHPF = exp(-2 * PI * high_cutoff * dt);
  float w0 = 2 * PI * f0 / fs;
  float alpha = sin(w0) / (2 * Q);
  float cosw0 = cos(w0);
  float a0_inv = 1.0 / (1.0 + alpha);

  notch_b0 = 1 * a0_inv; notch_b1 = (-2 * cosw0) * a0_inv; notch_b2 = 1 * a0_inv;
  notch_a1 = (-2 * cosw0) * a0_inv; notch_a2 = (1 - alpha) * a0_inv;

  float initialValue = (float)analogRead(ECG_PIN);
  yHPF_prev = 0; xHPF_prev = initialValue; yLPF_prev = initialValue;

  // 5. Setup MAX30102
  Wire.begin(21, 22);
  if (!particleSensor.begin(Wire, I2C_SPEED_FAST)) {
    display.clearDisplay();
    display.setCursor(0, 20);
    display.println("MAX30102 Error");
    display.display();
    while (1);
  }
  particleSensor.setup(60, 4, 2, 100, 411, 4096);

  display.clearDisplay();
}

void loop() {
  unsigned long nowUs = micros();
  unsigned long nowMs = millis();

  // Keep MQTT alive -- non-blocking, never stalls sensor reads or the OLED
  maintainMqttConnection();

  // --- Update Temperature every 1 second ---
  if (nowMs - lastTempRequest >= 1000) {
    bodyTempC = sensors.getTempCByIndex(0);
    sensors.requestTemperatures();
    lastTempRequest = nowMs;
  }

  // --- Main Sensor Loop (100 Hz) ---
  if (nowUs - lastSampleTime >= samplingPeriod) {
    lastSampleTime = nowUs;

    // 1. Read ECG
    int ecgOutput = 2048;

    if ((digitalRead(LO_PLUS) == 1) || (digitalRead(LO_MINUS) == 1)) {
      ecgBpm = 0; ecgBeatCount = 0;
    } else {
      float x = (float)analogRead(ECG_PIN);
      float y1 = highPassFilter(x);
      float y2 = lowPassFilter(y1);
      float y3 = notchFilter(y2);
      ecgOutput = (int)round(y3 + 2048.0f);

      if (ecgOutput > ECG_PEAK_THRESHOLD && (nowMs - lastEcgPeakTime > ECG_REFRACTORY_MS)) {
        unsigned long beatInterval = nowMs - lastEcgPeakTime;
        lastEcgPeakTime = nowMs;
        if (beatInterval > 300 && beatInterval < 2000) {
          float currentBpm = 60000.0 / beatInterval;
          ecgBpmHistory[ecgBpmIndex] = currentBpm;
          ecgBpmIndex = (ecgBpmIndex + 1) % 5;
          if (ecgBeatCount < 5) ecgBeatCount++;

          float sum = 0;
          for (int i = 0; i < ecgBeatCount; i++) sum += ecgBpmHistory[i];
          ecgBpm = sum / ecgBeatCount;
        }
      }
    }

    // NEW: capture this sample into the raw ECG window for the CNN
    ecgRawBuffer[ecgRawIndex] = (float)ecgOutput;
    ecgRawIndex++;
    if (ecgRawIndex >= 100) {
      publishTelemetry();   // fires once per second, once the window is full
      ecgRawIndex = 0;
    }

    // 2. Read MAX30102
    particleSensor.check();
    while (particleSensor.available()) {
      redBuffer[bufferIndex] = particleSensor.getFIFORed();
      irBuffer[bufferIndex] = particleSensor.getFIFOIR();
      particleSensor.nextSample();
      bufferIndex++;
      if (bufferIndex >= 100) break;
    }

    // 3. Send ONLY ECG to Serial Plotter
    Serial.println(ecgOutput);

    // 4. Calculate SpO2 & Update OLED (runs 4 times a second)
    if (bufferIndex >= 100) {
      maxim_heart_rate_and_oxygen_saturation(irBuffer, bufferLength, redBuffer, &spo2, &validSPO2, &heartRate, &validHeartRate);

      if (!validHeartRate || heartRate > 200 || heartRate < 30) heartRate = 0;
      if (!validSPO2 || spo2 > 100 || spo2 < 50) spo2 = 0;

      // OLED always updates locally, regardless of WiFi/MQTT status
      display.clearDisplay();
      display.setTextSize(2);

      display.setCursor(0, 0);
      display.print("ECG: ");
      if (ecgBpm > 0) display.print((int)ecgBpm);
      else display.print("--");

      display.setCursor(0, 16);
      display.print("MAX: ");
      if (heartRate > 0) display.print(heartRate);
      else display.print("--");

      display.setCursor(0, 32);
      display.print("O2 : ");
      if (spo2 > 0) { display.print(spo2); display.print("%"); }
      else display.print("--%");

      display.setCursor(0, 48);
      display.print("TMP: ");
      if (bodyTempC > -10.0) { display.print(bodyTempC, 1); display.print("C"); }
      else display.print("--C");

      display.display();

      for (byte i = 25; i < 100; i++) {
        redBuffer[i - 25] = redBuffer[i];
        irBuffer[i - 25] = irBuffer[i];
      }
      bufferIndex = 75;
    }
  }
}
